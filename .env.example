# ◉ 세상을 보는 눈 — 환경 변수 템플릿
#
# 사용법: 이 파일을 .env로 복사한 뒤 실제 값을 채우세요. (.env는 .gitignore로 커밋이 차단됩니다)
#   cp .env.example .env
# 수집기(scripts/collect.mjs)가 실행 시 .env를 자동 로드합니다 (없으면 조용히 건너뜀).
#
# ⚠ 현재 이 서비스는 API 키가 필요 없는 무료 공개 API/RSS만 사용합니다 — 지금은 채울 값이 없습니다.
#   아래 변수들은 향후 키가 필요한 소스를 추가할 때를 위한 자리입니다.
#
# 배포 환경에 등록하는 곳:
#   - GitHub Actions(현재 수집 경로): 저장소 Settings → Secrets and variables → Actions → New repository secret
#     등록 후 .github/workflows/daily-collect.yml의 수집 단계 env: 블록 주석을 해제해 주입
#   - Vercel: Project → Settings → Environment Variables
#   - Netlify: Site configuration → Environment variables
#   ⚠ 정적 사이트의 브라우저 JS에는 어떤 방식으로도 비밀 키를 넣지 마세요 — 소스 보기로 그대로 노출됩니다.
#     환경 변수는 수집기/빌드 단계(서버 측)에서만 사용해야 합니다.

# ── 향후 확장용 (현재 미사용 — 변수 이름만 유지) ──
NEWS_API_KEY=
TRANSLATE_API_KEY=
MARKET_API_KEY=

# ── 수집기 테스트 전용 (비밀 아님 — 로컬 개발 편의) ──
# SEBONOON_FIXTURES=   # fixture 디렉터리 경로 (네트워크 없이 수집기 실행)
# SEBONOON_DATA_DIR=   # 데이터 출력 디렉터리 (라이브 data/ 보호)
